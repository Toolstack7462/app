# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=toolstack_crm

# JWT Secrets (REQUIRED - Generate strong random strings)
# You can generate these using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-min-32-chars-change-this-in-production

# Cookies Encryption (REQUIRED - MUST BE 64 HEX CHARS)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIES_ENCRYPTION_KEY=your-64-char-hex-encryption-key-change-this-in-production

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# Server Configuration
CRM_PORT=8002
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Token Configuration
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Initial Admin Setup (Only used by seed script)
INITIAL_ADMIN_EMAIL=admin@toolstack.com
INITIAL_ADMIN_PASSWORD=ChangeThisPassword123!
INITIAL_ADMIN_NAME=Super Admin