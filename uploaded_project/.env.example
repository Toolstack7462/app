# ===================================
# TOOLSTACK CRM - Environment Variables
# ===================================

# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_secure_mongo_password_here
DB_NAME=toolstack_crm

# JWT Secrets (REQUIRED - Generate strong random strings)
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-128-chars-minimum
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-128-chars-minimum

# Cookies Encryption (REQUIRED - MUST BE 64 HEX CHARS)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIES_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# Frontend Configuration
REACT_APP_BACKEND_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SSL Certificate (for Let's Encrypt)
DOMAIN=yourdomain.com
SSL_EMAIL=your-email@example.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Token Configuration
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Node Environment
NODE_ENV=production

# Initial Admin Setup (only used by seed script)
INITIAL_ADMIN_EMAIL=admin@toolstack.com
INITIAL_ADMIN_PASSWORD=ChangeThisPassword123!
INITIAL_ADMIN_NAME=Super Admin